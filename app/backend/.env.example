# VigilAI Backend Environment Variables

# Firecrawl API Key配置
# 方式1: 单个API Key
FIRECRAWL_API_KEY=your_api_key_here

# 方式2: 多个API Key（用逗号分隔，请求会轮流使用这些key）
# 例如有3个账号，每个500次/月，总共1500次/月
FIRECRAWL_API_KEYS=key1,key2,key3

# 详情页抓取配置
# 是否抓取活动详情页的完整内容（会消耗更多API调用）
FETCH_DETAIL_CONTENT=false
# 每个信息源最多抓取多少个详情页
DETAIL_FETCH_MAX_COUNT=10
# 详情页抓取间隔（秒）
DETAIL_FETCH_DELAY=2.0

# 可选: 日志级别
LOG_LEVEL=INFO
# Agent analysis provider routing
ANALYSIS_PROVIDER=mock
ANALYSIS_OPENAI_API_KEY=

# Model routing
ANALYSIS_SCREENING_MODEL=gpt-4o-mini
ANALYSIS_SCREENING_MODEL_LOW=gpt-4o-mini
ANALYSIS_SCREENING_FALLBACK_MODEL=gpt-4o-mini
ANALYSIS_RESEARCH_MODEL=gpt-4o
ANALYSIS_RESEARCH_FALLBACK_MODEL=gpt-4o
ANALYSIS_VERDICT_MODEL=gpt-4o
ANALYSIS_VERDICT_FALLBACK_MODEL=gpt-4o

# Budget and research guardrails
ANALYSIS_BUDGET_LOW_TOKEN_LIMIT=4000
ANALYSIS_BUDGET_DEFAULT_TOKEN_LIMIT=12000
ANALYSIS_BUDGET_HIGH_TOKEN_LIMIT=24000
ANALYSIS_RESEARCH_MAX_URLS=5
ANALYSIS_RESEARCH_MAX_DOMAINS=3
ANALYSIS_RESEARCH_TIMEOUT_SECONDS=45

# Scheduled batch analysis
ANALYSIS_SCHEDULER_ENABLED=false
ANALYSIS_SCHEDULE_MAX_ITEMS=25
